@page "/"
@using BackTester.Strategies
@using Engine.Charts
@using Engine.Charts.Plots
@using Engine.Charts.Plots.Candle
@using Engine.Charts.Plots.Line
@using Engine.Charts.Plots.Area
@using Engine.Core
@using Engine.Strategies
@using Engine.Indicators
@using LightweightCharts.Blazor.Charts
@using LightweightCharts.Blazor.Customization.Enums
@using LightweightCharts.Blazor.Customization.Series
@using LightweightCharts.Blazor.Series
@using LightweightCharts.Blazor.Customization.Chart
@using LightweightCharts.Blazor.DataItems
@using LightweightCharts.Blazor.Models
@using LightweightCharts.Blazor.Models.Events
@using System.Reflection
@inject IJSRuntime JS
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<div style="display:flex; justify-content:space-between; align-items:center;">
    <h1>Dashboard</h1>
</div>

<style>
    body {
        background-color: #131722;
        color: #d1d4dc;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }
    .chart-container {
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding: 20px;
        max-width: 1400px;
        margin: 0 auto;
    }
    .chart-wrapper {
        display: flex;
        flex-direction: row;
        width: 100%;
        gap: 15px;
    }
    .main-chart {
        flex: 1;
        height: 60vh;
        border: 1px solid #2B2B43;
        border-radius: 8px;
        overflow: hidden;
        background-color: #1E222D;
    }
    .sub-chart {
        flex: 1;
        height: 30vh;
        border: 1px solid #2B2B43;
        border-radius: 8px;
        overflow: hidden;
        background-color: #1E222D;
    }
    .chart-metrics {
        width: 250px;
        background-color: #1E222D;
        border: 1px solid #2B2B43;
        border-radius: 8px;
        padding: 15px;
        overflow-y: auto;
    }
    .metric-item {
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        font-size: 14px;
    }
    .metric-key {
        font-weight: bold;
        color: #B2B5BE;
        cursor: help;
        text-decoration: underline dotted;
    }
    .metric-value {
        color: #FFFFFF;
    }
    .tabs {
        display: flex;
        border-bottom: 1px solid #2B2B43;
        margin-bottom: 10px;
    }
    .tab {
        flex: 1;
        padding: 5px;
        text-align: center;
        cursor: pointer;
        color: #B2B5BE;
        font-size: 14px;
    }
    .tab.active {
        color: #2962FF;
        border-bottom: 2px solid #2962FF;
    }
</style>

<div class="chart-container">
    <div class="chart-wrapper">
        <div class="charts-column" style="display: flex; flex-direction: column; flex: 1; min-width: 0; min-height: 0;" @key="_chartKey">
            <div class="main-chart">
                <ChartComponent @ref="_mainChart" />
            </div>

            @if (_chartDatas != null)
            {
                var underChartGroups = _chartDatas
                    .Where(c => c.Postion == Engine.Enums.PlotPositionEnum.UnderChart)
                    .GroupBy(c => c.ChartName)
                    .ToList();

                @for (var i = 0; i < _underChartCount; i++)
                {
                    var currentIndex = i;
                    var groupName = underChartGroups.ElementAtOrDefault(currentIndex)?.Key ?? "Under";
                    <div class="sub-chart" style="margin-top: 15px;">
                        <ChartComponent @ref="_underCharts[currentIndex]" />
                    </div>
                    <div class="chart-metrics" style="display: none;">
                        <!-- Hidden subchart metrics placeholder -->
                    </div>
                }
            }
        </div>

        <div class="chart-metrics" style="width: 250px;">
            <div class="tabs">
                <div class="tab @(_activeTab == "Stats" ? "active" : "")" @onclick="@(() => _activeTab = "Stats")">Stats</div>
                <div class="tab @(_activeTab == "Settings" ? "active" : "")" @onclick="@(() => _activeTab = "Settings")">Settings</div>
            </div>

            @if(_activeTab == "Stats")
            {
                @if (_chartMetrics.TryGetValue("Main", out var mainMetrics))
                {
                    @foreach (var kvp in mainMetrics)
                    {
                        <div class="metric-item">
                            <span class="metric-key" title="@GetTooltip(kvp.Key)">@kvp.Key:</span>
                            <span class="metric-value">@kvp.Value</span>
                        </div>
                    }
                }
                @if (_chartDatas != null)
                {
                    var underChartGroups = _chartDatas
                        .Where(c => c.Postion == Engine.Enums.PlotPositionEnum.UnderChart)
                        .GroupBy(c => c.ChartName)
                        .ToList();

                    @for (var i = 0; i < _underChartCount; i++)
                    {
                        var groupName = underChartGroups.ElementAtOrDefault(i)?.Key ?? "Under";
                        <h4 style="margin-top: 15px; color: #fff; padding-bottom: 5px; border-bottom: 1px solid #2B2B43">@groupName</h4>
                        if (_chartMetrics.TryGetValue(groupName, out var underMetrics))
                        {
                            foreach (var kvp in underMetrics)
                            {
                                <div class="metric-item">
                                    <span class="metric-key" title="@GetTooltip(kvp.Key)">@kvp.Key:</span>
                                    <span class="metric-value">@kvp.Value</span>
                                </div>
                            }
                        }
                    }
                }
            }
            else
            {
                @if(_liveStrategy != null)
                {
                    @RenderIndicatorEditor(_liveStrategy, _liveStrategy.GetType().Name)
                }
            }
        </div>
    </div>

</div>

@code {
    private string _activeTab = "Stats";
    private ChartComponent _mainChart = default!; 
    private int _underChartCount = 0;
    private ChartComponent[] _underCharts = Array.Empty<ChartComponent>();
    private IEnumerable<IPlotSerie<IPlot, ISerieConfig>>? _chartDatas;
    private bool _chartsInitialized;
    private bool _isSyncing = false;
    private Dictionary<string, Dictionary<string, string>> _chartMetrics = new();
    private Dictionary<string, ChartComponent> _underChartMap = new();
    private Dictionary<string, ISeriesApi<long>> _primarySeriesMap = new();
    private bool _isSyncingCrosshair = false;
    private int _chartKey = 0;
    private Chart _chart;
    private IStrategy _liveStrategy;
    private CancellationTokenSource? _debounceCts;

    private async Task HandleInputChanged(PropertyInfo prop, IIndicator indicator, ChangeEventArgs e)
    {
        try
        {
            object val;
            if (prop.PropertyType == typeof(System.Drawing.Color))
            {
                val = System.Drawing.ColorTranslator.FromHtml(e.Value?.ToString() ?? "#FFFFFF");
            }
            else
            {
                val = Convert.ChangeType(e.Value, prop.PropertyType);
            }
            prop.SetValue(indicator, val);

            if (_debounceCts != null)
            {
                _debounceCts.Cancel();
                _debounceCts.Dispose();
            }

            _debounceCts = new CancellationTokenSource();
            var token = _debounceCts.Token;

            await Task.Delay(500, token);
            
            if (!token.IsCancellationRequested)
            {
                await ReloadChart();
            }
        }
        catch (Exception)
        {
            // Ignore format parsing errors during typing
        }
    }

    private RenderFragment RenderIndicatorEditor(IIndicator indicator, string name) => __builder =>
    {
        if (indicator == null) return;

        <div class="indicator-editor" style="margin-bottom: 15px; border-left: 2px solid #2B2B43; padding-left: 10px;">
            <h5 style="color: #2962FF; margin-top: 5px; margin-bottom: 10px;">@name</h5>
            @{
                var type = indicator.GetType();
                var props = type.GetProperties(BindingFlags.Public | BindingFlags.Instance)
                                .Where(p => p.CanRead && p.CanWrite);

                foreach (var prop in props)
                {
                    <div class="property-row" style="margin-bottom: 8px; display:flex; justify-content: space-between; align-items: center;">
                        <span style="color: #B2B5BE; font-size: 13px;">@prop.Name</span>
                        @{
                            var val = prop.GetValue(indicator);
                            if (prop.PropertyType == typeof(int))
                            {
                                <input type="number" value="@val" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; color: white; border: 1px solid #2B2B43; padding: 2px 5px; width: 60px; border-radius: 3px;" />
                            }
                            else if (prop.PropertyType == typeof(decimal))
                            {
                                <input type="number" step="0.01" value="@val" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; color: white; border: 1px solid #2B2B43; padding: 2px 5px; width: 60px; border-radius: 3px;" />
                            }
                            else if (prop.PropertyType == typeof(System.Drawing.Color))
                            {
                                var c = (System.Drawing.Color)val;
                                var hex = $"#{c.R:X2}{c.G:X2}{c.B:X2}";
                                <input type="color" value="@hex" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; border: 1px solid #2B2B43;" />
                            }
                            else
                            {
                                <input type="text" value="@val" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; color: white; border: 1px solid #2B2B43; padding: 2px 5px; width: 60px; border-radius: 3px;" />
                            }
                        }
                    </div>
                }

                int childIndex = 0;
                foreach (var child in indicator.Indicators)
                {
                    @RenderIndicatorEditor(child, child.GetType().Name.Replace("Indicator", "") + " " + (++childIndex))
                }
            }
        </div>
    };

    private string GetTooltip(string metricName)
    {
        return metricName switch
        {
            "Sharpe Ratio" => "Mesure le rendement de la stratégie corrigé de son risque total (Volatilité). Plus c'est élevé, meilleur est le profil rendement/risque.",
            "Sortino Ratio" => "Comme le Sharpe, mais ne pénalise que la volatilité à la baisse (le vrai risque). Un ratio élevé signifie des rendements consistants avec peu de grosses chutes.",
            "Omega Ratio" => "Ratio de la somme des gains sur la somme des pertes. Évalue l'asymétrie totale d'une stratégie de manière probabiliste.",
            "Calmar Ratio" => "Rendement total divisé par le Max Drawdown. Mesure la tolérance à la douleur pour atteindre ce rendement.",
            "Beta (β)" => "Mesure la volatilité systématique (corrélation) de la stratégie par rapport au marché (Buy & Hold). Beta = 1 : Mouvements identiques au marché. Beta < 1 : Plus stable.",
            "Jensen's Alpha (α)" => "La surperformance (ou sous-performance) pure de la stratégie après déduction du risque marché (Beta). C'est le vrai 'edge' de la stratégie.",
            "Information Ratio" => "Rendement excédentaire divisé par le Tracking Error. Mesure la régularité mathématique à battre le marché de référence de façon constante.",
            "Kelly Criterion" => "Algorithme probabiliste suggérant quel pourcentage de capital risquer sur ce signal de trading pour maximiser la croissance à long terme en évitant la ruine.",
            "Recovery Factor" => "Profit net divisé par la pire chute en argent (Net Profit / Max Drawdown $). Affiche la capacité de survie du fond.",
            "Profit Factor" => "Gains bruts divisés par les Pertes brutes. Doit être strictement supérieur à 1 pour garantir une profitabilité structurelle.",
            "Payoff Ratio" => "La taille moyenne d'un trade gagnant divisée par la taille absolue d'un trade perdant.",
            "Expectancy ($)" => "L'espérance mathématique : ce que la stratégie gagne ou perd 'en moyenne' à chaque transaction exécutée.",
            _ => "Analyse en temps réel de l'évolution du portefeuille."
        };
    }

    private void CopyProperties(IIndicator source, IIndicator target)
    {
        var props = source.GetType().GetProperties(BindingFlags.Public | BindingFlags.Instance).Where(p => p.CanRead && p.CanWrite);
        foreach(var prop in props)
        {
            prop.SetValue(target, prop.GetValue(source));
        }
        for(int i = 0; i < source.Indicators.Count; i++)
        {
            if (i < target.Indicators.Count)
            {
                CopyProperties(source.Indicators[i], target.Indicators[i]);
            }
        }
    }

    private async Task ReloadChart()
    {
        _chartsInitialized = false;
        _chartKey++;

        var newStrategy = (IStrategy)Activator.CreateInstance(_liveStrategy.GetType(), 1000m);
        
        var newChart = new Chart()
        {
            HistoryFrom = _chart.HistoryFrom,
            DateFrom = _chart.DateFrom,
            Strategy = newStrategy,
            Symbol = new Symbol("BTC-USD")
        };

        var context = new Context(newChart);
        await context.PrepareAsync();
        
        CopyProperties(_liveStrategy, newChart.Strategy);

        _chartDatas = await context.ExecuteOnlyAsync();
        _chart = newChart;
        
        _primarySeriesMap.Clear();
        _underChartMap.Clear();
        _chartMetrics.Clear();
        
        if (_chartDatas != null)
        {
            var underChartGroups = _chartDatas
                .Where(c => c.Postion == Engine.Enums.PlotPositionEnum.UnderChart)
                .GroupBy(c => c.ChartName)
                .ToList();

            _underChartCount = underChartGroups.Count;
            _underCharts = new ChartComponent[_underChartCount];
        }
        StateHasChanged();
    }

    private async void SyncLogicalRange(object? sender, LogicalRange e)
    {
        if (_isSyncing || e == null) return;
        _isSyncing = true;
        try
        {
            if (_mainChart != null) 
            {
                var ts = await _mainChart.TimeScale();
                await ts.SetVisibleLogicalRange(e);
            }
            foreach (var c in _underCharts)
            {
                if (c != null) 
                {
                    var ts = await c.TimeScale();
                    await ts.SetVisibleLogicalRange(e);
                }
            }
        }
        finally
        {
            _isSyncing = false;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _chart = new Chart()
        {
            HistoryFrom = new DateTime(2017, 01, 01),
            DateFrom = new DateTime(2018, 01, 01),
            Strategy = new SmaCrossingStrategy(1000),
            Symbol = new Symbol("BTC-USD")
        };
        _liveStrategy = _chart.Strategy;

        var context = new Context(_chart);
        await context.PrepareAsync();
        _chartDatas = await context.ExecuteOnlyAsync();

        if (_chartDatas != null)
        {
            var underChartGroups = _chartDatas
                .Where(c => c.Postion == Engine.Enums.PlotPositionEnum.UnderChart)
                .GroupBy(c => c.ChartName)
                .ToList();

            _underChartCount = underChartGroups.Count;
            _underCharts = new ChartComponent[_underChartCount];
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_chartDatas != null && !_chartsInitialized)
        {
            if (_underChartCount > 0 && _underCharts.Any(c => c == null))
            {
                return; 
            }

            _chartsInitialized = true;

            if (_mainChart != null)
            {
                await _mainChart.InitializationCompleted;
                var tsMain = await _mainChart.TimeScale();
                tsMain.VisibleLogicalRangeChanged += SyncLogicalRange;
                _mainChart.CrosshairMoved += (sender, e) => OnCrosshairMoved("Main", e);
            }

            foreach (var c in _underCharts)
            {
                if (c != null)
                {
                    await c.InitializationCompleted;
                    var ts = await c.TimeScale();
                    ts.VisibleLogicalRangeChanged += SyncLogicalRange;
                }
            }

            var underChartGroups = _chartDatas
                .Where(c => c.Postion == Engine.Enums.PlotPositionEnum.UnderChart)
                .GroupBy(c => c.ChartName)
                .ToList();

            int currentUnderChartIndex = 0;
            foreach (var group in underChartGroups)
            {
                var chartName = group.Key;
                var c = _underCharts[currentUnderChartIndex++];
                _underChartMap[chartName] = c;
                c.CrosshairMoved += (sender, e) => OnCrosshairMoved(chartName, e);
            }

            foreach (var chartData in _chartDatas)
            {
                var targetChart = _mainChart;
                var mapKey = "Main";

                if (chartData.Postion == Engine.Enums.PlotPositionEnum.Hidden) continue;

                if (chartData.Postion == Engine.Enums.PlotPositionEnum.UnderChart)
                {
                    targetChart = _underChartMap[chartData.ChartName];
                    mapKey = chartData.ChartName;
                }

                if (targetChart == null) continue;

                ISeriesApi<long> series = null;
                switch (chartData.Type)
                {
                    case Engine.Enums.PlotTypeEnum.Line:
                        if (chartData is IPlotSerie<PlotLine, PlotLineSerieConfig> lineData)
                            series = (ISeriesApi<long>) await SetLineSerieAsync(targetChart, lineData);
                        break;
                    case Engine.Enums.PlotTypeEnum.Candle:
                        if (chartData is IPlotSerie<PlotCandle, PlotCandleSerieConfig> candleData)
                            series = (ISeriesApi<long>) await SetCandleSticksSerieAsync(targetChart, candleData);
                        break;
                    case Engine.Enums.PlotTypeEnum.Area:
                        if (chartData is IPlotSerie<PlotArea, AreaSerieConfig> areaData)
                            series = (ISeriesApi<long>) await SetAreaSerieAsync(targetChart, areaData);
                        break;
                }

                if (series != null && !_primarySeriesMap.ContainsKey(mapKey))
                {
                    _primarySeriesMap[mapKey] = series;
                }
            }

            UpdateMetrics("Main", null);
            foreach (var group in underChartGroups)
            {
                UpdateMetrics(group.Key, null);
            }
            StateHasChanged();
        }
    }

    private async void OnCrosshairMoved(string chartName, MouseEventParams<long> e)
    {
        UpdateMetrics(chartName, e.Time);

        if (_isSyncingCrosshair) return;
        _isSyncingCrosshair = true;
        try
        {
            var underGroups = _chartDatas?.Where(c => c.Postion == Engine.Enums.PlotPositionEnum.UnderChart).GroupBy(c => c.ChartName).Select(g => g.Key).ToList() ?? new List<string>();

            if (e.Time.HasValue)
            {
                var targetTime = e.Time.Value;
                
                if (chartName != "Main" && _mainChart != null)
                {
                    UpdateMetrics("Main", targetTime);
                    if (_primarySeriesMap.TryGetValue("Main", out var serieMain))
                    {
                        await _mainChart.SetCrosshairPosition(0, targetTime, serieMain);
                    }
                }
                
                foreach (var targetChartName in underGroups)
                {
                    if (targetChartName != chartName && _underChartMap.TryGetValue(targetChartName, out var chartComp))
                    {
                        UpdateMetrics(targetChartName, targetTime);
                        if (_primarySeriesMap.TryGetValue(targetChartName, out var targetSerie))
                        {
                            await chartComp.SetCrosshairPosition(0, targetTime, targetSerie);
                        }
                    }
                }
            }
            else
            {
                if (chartName != "Main" && _mainChart != null) 
                {
                    UpdateMetrics("Main", null);
                    await _mainChart.ClearCrosshairPosition();
                }
                foreach (var targetChartName in underGroups)
                {
                    if (targetChartName != chartName && _underChartMap.TryGetValue(targetChartName, out var chartComp))
                    {
                        UpdateMetrics(targetChartName, null);
                        await chartComp.ClearCrosshairPosition();
                    }
                }
            }
        }
        catch { }
        finally
        {
            _isSyncingCrosshair = false;
        }
    }

    private void UpdateMetrics(string chartName, long? unixTime)
    {
        if (_chartDatas == null) return;
        
        IEnumerable<IPlotSerie<IPlot, ISerieConfig>> series = Enumerable.Empty<IPlotSerie<IPlot, ISerieConfig>>();
        if (chartName == "Main")
            series = _chartDatas.Where(c => c.Postion == Engine.Enums.PlotPositionEnum.OnChart);
        else
            series = _chartDatas.Where(c => c.ChartName == chartName);

        if (series == null || !series.Any()) return;

        DateTime targetTime;
        if (unixTime.HasValue) 
        {
            targetTime = DateTimeOffset.FromUnixTimeSeconds(unixTime.Value).UtcDateTime;
        } 
        else 
        {
            var allKeys = series.SelectMany(s => s.Metrics?.Keys ?? Enumerable.Empty<DateTime>()).ToList();
            targetTime = allKeys.Any() ? allKeys.Max() : DateTime.MinValue;
            if (targetTime == DateTime.MinValue) return;
        }

        var combinedMetrics = new Dictionary<string, string>();
        foreach(var s in series) 
        {
            if (s.Metrics == null || !s.Metrics.Any()) continue;
            var matches = s.Metrics.Keys.Where(k => k <= targetTime);
            if (matches.Any())
            {
                var closestTime = matches.Max();
                if (s.Metrics.TryGetValue(closestTime, out var dict))
                {
                    foreach(var kvp in dict) 
                    {
                        combinedMetrics[kvp.Key] = kvp.Value;
                    }
                }
            }
        }

        _chartMetrics[chartName] = combinedMetrics;
        InvokeAsync(StateHasChanged);
    }

    private async Task ApplyDarkModeOptions(ChartComponent chart)
    {
        if (chart == null) return;

        var options = new ChartOptions
        {
            AutoSize = true,
            Layout = new LayoutOptions
            {
                TextColor = System.Drawing.ColorTranslator.FromHtml("#d1d4dc"),
            },
            Grid = new GridOptions
            {
            },
            TimeScale = new TimeScaleOptions
            {
                TimeVisible = true,
                RightOffset = 5
            }
        };

        try
        {
            await chart.ApplyOptions(options);
        }
        catch { }
    }


    private SeriesMarkerBarPosition MapMarkerPosition(Engine.Charts.Plots.MarkerPosition pos)
    {
        return pos switch
        {
            Engine.Charts.Plots.MarkerPosition.AboveBar => SeriesMarkerBarPosition.AboveBar,
            Engine.Charts.Plots.MarkerPosition.BelowBar => SeriesMarkerBarPosition.BelowBar,
            Engine.Charts.Plots.MarkerPosition.InBar => SeriesMarkerBarPosition.InBar,
            _ => SeriesMarkerBarPosition.AboveBar
        };
    }

    private SeriesMarkerShape MapMarkerShape(Engine.Charts.Plots.MarkerShape shape)
    {
        return shape switch
        {
            Engine.Charts.Plots.MarkerShape.Circle => SeriesMarkerShape.Circle,
            Engine.Charts.Plots.MarkerShape.ArrowUp => SeriesMarkerShape.ArrowUp,
            Engine.Charts.Plots.MarkerShape.ArrowDown => SeriesMarkerShape.ArrowDown,
            Engine.Charts.Plots.MarkerShape.Square => SeriesMarkerShape.Square,
            _ => SeriesMarkerShape.Circle
        };
    }

    private async Task<ISeriesApi<long>> SetLineSerieAsync(ChartComponent chart, IPlotSerie<PlotLine, PlotLineSerieConfig> chartData)
    {
        if (chartData == null) return null;
        await ApplyDarkModeOptions(chart);
        var color = string.IsNullOrEmpty(chartData.Config.Color) ? "#2962FF" : chartData.Config.Color;
        var series = await chart.AddSeries<LineStyleOptions>(SeriesType.Line, new LineStyleOptions()
        {
            Color = System.Drawing.ColorTranslator.FromHtml(color),
            Title = string.IsNullOrEmpty(chartData.Name) ? chartData.ChartName : chartData.Name
        });
        var data = chartData.Plots.Select(a => new LineData<long>()
        {
            Time = new DateTimeOffset(a.Time).ToUnixTimeSeconds(),
            Value = (double)a.Value
        });

        await series.SetData(data);

        if (chartData.Markers != null && chartData.Markers.Any())
        {
            var markers = chartData.Markers.Select(m => new SeriesMarkerBar<long>()
            {
                Time = new DateTimeOffset(m.Time).ToUnixTimeSeconds(),
                Position = MapMarkerPosition(m.Position),
                Shape = MapMarkerShape(m.Shape),
                Color = System.Drawing.ColorTranslator.FromHtml(string.IsNullOrEmpty(m.Color) ? "#26a69a" : m.Color),
                Text = m.Text ?? "",
                Size = 1
            });
            await series.CreateSeriesMarkers(markers);
        }
        return series;
    }

    private async Task<ISeriesApi<long>> SetCandleSticksSerieAsync(ChartComponent chart, IPlotSerie<PlotCandle, PlotCandleSerieConfig> chartData)
    {
        if (chartData == null) return null;
        await ApplyDarkModeOptions(chart);
        var upColor = string.IsNullOrEmpty(chartData.Config.UpColor) ? "#26a69a" : chartData.Config.UpColor;
        var downColor = string.IsNullOrEmpty(chartData.Config.DownColor) ? "#ef5350" : chartData.Config.DownColor;
        var wickUpColor = string.IsNullOrEmpty(chartData.Config.WickUpColor) ? "#26a69a" : chartData.Config.WickUpColor;
        var wickDownColor = string.IsNullOrEmpty(chartData.Config.WickDownColor) ? "#ef5350" : chartData.Config.WickDownColor;

        var series = await chart.AddSeries<CandlestickStyleOptions>(SeriesType.Candlestick, new CandlestickStyleOptions()
        {
            UpColor = System.Drawing.ColorTranslator.FromHtml(upColor),
            DownColor = System.Drawing.ColorTranslator.FromHtml(downColor),
            BorderVisible = chartData.Config.BorderVisible,
            WickDownColor = System.Drawing.ColorTranslator.FromHtml(wickDownColor),
            WickUpColor = System.Drawing.ColorTranslator.FromHtml(wickUpColor),
            Title = string.IsNullOrEmpty(chartData.Name) ? chartData.ChartName : chartData.Name
        });

        var data = chartData.Plots.Select(a => new CandlestickData<long>()
        {
            Time = new DateTimeOffset(a.Time).ToUnixTimeSeconds(),
            Close = (double)a.Close,
            High = (double)a.High,
            Low = (double)a.Low,
            Open = (double)a.Open,
        });

        await series.SetData(data);

        if (chartData.Markers != null && chartData.Markers.Any())
        {
            var markers = chartData.Markers.Select(m => new SeriesMarkerBar<long>()
            {
                Time = new DateTimeOffset(m.Time).ToUnixTimeSeconds(),
                Position = MapMarkerPosition(m.Position),
                Shape = MapMarkerShape(m.Shape),
                Color = System.Drawing.ColorTranslator.FromHtml(string.IsNullOrEmpty(m.Color) ? "#26a69a" : m.Color),
                Text = m.Text ?? "",
                Size = 1
            });
            await series.CreateSeriesMarkers(markers);
        }
        return series;
    }

    private async Task<ISeriesApi<long>> SetAreaSerieAsync(ChartComponent chart, IPlotSerie<PlotArea, AreaSerieConfig> chartData)
    {
        if (chartData == null) return null;
        await ApplyDarkModeOptions(chart);
        var color = string.IsNullOrEmpty(chartData.Config.Color) ? "#2962FF" : chartData.Config.Color;
        var series = await chart.AddSeries<AreaStyleOptions>(SeriesType.Area, new AreaStyleOptions()
        {
            BaseLineColor = System.Drawing.ColorTranslator.FromHtml(color),
            Title = string.IsNullOrEmpty(chartData.Name) ? chartData.ChartName : chartData.Name
        });

        var data = chartData.Plots.Select(a => new AreaData<long>()
        {
            Time = new DateTimeOffset(a.Time).ToUnixTimeSeconds(),
            Value = (double)a.Value
        });

        await series.SetData(data);

        if (chartData.Markers != null && chartData.Markers.Any())
        {
            var markers = chartData.Markers.Select(m => new SeriesMarkerBar<long>()
            {
                Time = new DateTimeOffset(m.Time).ToUnixTimeSeconds(),
                Position = MapMarkerPosition(m.Position),
                Shape = MapMarkerShape(m.Shape),
                Color = System.Drawing.ColorTranslator.FromHtml(string.IsNullOrEmpty(m.Color) ? "#26a69a" : m.Color),
                Text = m.Text ?? "",
                Size = 1
            });
            await series.CreateSeriesMarkers(markers);
        }
        return series;
    }
