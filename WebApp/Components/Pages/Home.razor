@page "/"
@using Engine.Enums
@using Engine.Indicators
@using LightweightCharts.Blazor.Charts
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<style>
    body {
        background-color: #131722;
        color: #d1d4dc;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    }

    .app-layout {
        display: flex;
        flex-direction: row;
        height: 100vh;
        overflow: hidden;
    }

    .sidebar {
        width: 240px;
        min-width: 240px;
        background-color: #1a1e29;
        border-right: 1px solid #2B2B43;
        overflow-y: auto;
        padding: 16px;
        flex-shrink: 0;
    }

    .sidebar-item {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 6px 4px;
        border-radius: 4px;
        cursor: pointer;
        color: #d1d4dc;
        font-size: 13px;
        transition: background 0.15s;
    }

    .sidebar-item:hover { background: rgba(41, 98, 255, 0.1); }
    .sidebar-item.selected { background: rgba(41, 98, 255, 0.2); color: #fff; }

    .sidebar-section-title {
        color: #B2B5BE;
        font-size: 11px;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        margin: 16px 0 6px 4px;
    }

    .sidebar-section-title:first-child { margin-top: 0; }

    .chart-container {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding: 20px;
        overflow-y: auto;
    }

    .chart-wrapper {
        display: flex;
        flex-direction: row;
        width: 100%;
        gap: 15px;
    }

    .main-chart {
        flex: 1;
        height: 60vh;
        border: 1px solid #2B2B43;
        border-radius: 8px;
        overflow: hidden;
        background-color: #1E222D;
    }

    .sub-chart {
        flex: 1;
        height: 30vh;
        border: 1px solid #2B2B43;
        border-radius: 8px;
        overflow: hidden;
        background-color: #1E222D;
    }

    .chart-metrics {
        width: 250px;
        background-color: #1E222D;
        border: 1px solid #2B2B43;
        border-radius: 8px;
        padding: 15px;
        overflow-y: auto;
    }

    .metric-item {
        margin-bottom: 8px;
        display: flex;
        justify-content: space-between;
        font-size: 14px;
    }

    .metric-key {
        font-weight: bold;
        color: #B2B5BE;
        cursor: help;
        text-decoration: underline dotted;
    }

    .metric-value { color: #FFFFFF; }

    .tabs {
        display: flex;
        border-bottom: 1px solid #2B2B43;
        margin-bottom: 10px;
    }

    .tab {
        flex: 1;
        padding: 5px;
        text-align: center;
        cursor: pointer;
        color: #B2B5BE;
        font-size: 14px;
    }

    .tab.active {
        color: #2962FF;
        border-bottom: 2px solid #2962FF;
    }

    .sticky-portfolio {
        position: sticky;
        bottom: 0px;
        z-index: 50;
        background-color: #131722;
        padding-top: 15px;
        padding-bottom: 15px;
        margin-left: -20px;
        margin-right: -20px;
        padding-left: 20px;
        padding-right: 20px;
        border-top: 2px solid #2B2B43;
        box-shadow: 0 -10px 20px rgba(0, 0, 0, 0.5);
        height: 300px;
    }
</style>

<div class="app-layout">
    <div class="sidebar">
        <div class="sidebar-section-title">Stratégies</div>
        @foreach (var t in _availableStrategies)
        {
            <div class="sidebar-item @(_selectedStrategyType == t ? "selected" : "")" 
                 @onclick="@(() => OnSelectStrategy(t))">
                <span>&#9654;</span> @t.Name.Replace("Strategy", "")
            </div>
        }

        <div class="sidebar-section-title">Indicateurs</div>
        @foreach (var t in _availableIndicators)
        {
            var isChecked = _selectedIndicatorTypes.Contains(t);
            <div class="sidebar-item @(isChecked ? "selected" : "")" 
                 @onclick="@(() => OnToggleIndicator(t))">
                <input type="checkbox" checked="@isChecked" style="pointer-events:none;" />
                @t.Name.Replace("Indicator", "")
            </div>
        }
    </div>

    <div class="chart-container">
        <div class="chart-wrapper">
            <div class="main-chart">
                <ChartComponent @ref="_mainChart" />
            </div>
            <div class="chart-metrics">
                <div class="tabs">
                    <div class="tab @(_activeTab == "Stats" ? "active" : "")" @onclick="@(() => _activeTab = "Stats")">Stats</div>
                    <div class="tab @(_activeTab == "Settings" ? "active" : "")" @onclick="@(() => _activeTab = "Settings")">Settings</div>
                </div>

                @if (_activeTab == "Stats")
                {
                    @if (_chartMetrics.TryGetValue("Main", out var mainMetrics))
                    {
                        @foreach (var kvp in mainMetrics)
                        {
                            <div class="metric-item">
                                <span class="metric-key" title="@GetTooltip(kvp.Key)">@kvp.Key:</span>
                                <span class="metric-value">@kvp.Value</span>
                            </div>
                        }
                    }
                }
                else
                {
                    @if (_liveStrategy != null)
                    {
                        @RenderIndicatorEditor(_liveStrategy, _liveStrategy.GetType().Name)
                    }
                }
            </div>
        </div>

        @if (_chartDatas != null)
        {
            @foreach (var currGroupName in _underChartGroupNames)
            {
                var groupName = currGroupName;
                var isStickyClass = groupName == "Portfolio" ? "sticky-portfolio" : "";

                <div class="chart-wrapper @isStickyClass" @key="groupName">
                    <div class="sub-chart">
                        <ChartComponent @ref="_underChartMap[groupName]" />
                    </div>
                    <div class="chart-metrics">
                        <h4 style="margin-top: 0; color: #fff; padding-bottom: 5px; border-bottom: 1px solid #2B2B43">@groupName Stats</h4>
                        @if (_chartMetrics.TryGetValue(groupName, out var underMetrics))
                        {
                            @foreach (var kvp in underMetrics)
                            {
                                <div class="metric-item">
                                    <span class="metric-key" title="@GetTooltip(kvp.Key)">@kvp.Key:</span>
                                    <span class="metric-value">@kvp.Value</span>
                                </div>
                            }
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

@code {
    private RenderFragment RenderIndicatorEditor(IIndicator indicator, string name) => __builder =>
    {
        if (indicator == null) return;

        <div class="indicator-editor" style="margin-bottom: 15px; border-left: 2px solid #2B2B43; padding-left: 10px;">
            <h5 style="color: #2962FF; margin-top: 5px; margin-bottom: 10px;">@name</h5>
            @{
                var type = indicator.GetType();
                var props = type.GetProperties(System.Reflection.BindingFlags.Public | System.Reflection.BindingFlags.Instance)
                                .Where(p => p.CanRead && p.CanWrite);

                foreach (var prop in props)
                {
                    <div class="property-row" style="margin-bottom: 8px; display:flex; justify-content: space-between; align-items: center;">
                        <span style="color: #B2B5BE; font-size: 13px;">@prop.Name</span>
                        @{
                            var val = prop.GetValue(indicator);
                            if (prop.PropertyType == typeof(int))
                            {
                                <input type="number" value="@val" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; color: white; border: 1px solid #2B2B43; padding: 2px 5px; width: 60px; border-radius: 3px;" />
                            }
                            else if (prop.PropertyType == typeof(decimal))
                            {
                                <input type="number" step="0.01" value="@val" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; color: white; border: 1px solid #2B2B43; padding: 2px 5px; width: 60px; border-radius: 3px;" />
                            }
                            else if (prop.PropertyType == typeof(System.Drawing.Color))
                            {
                                var c = (System.Drawing.Color)val;
                                var hex = $"#{c.R:X2}{c.G:X2}{c.B:X2}";
                                <input type="color" value="@hex" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; border: 1px solid #2B2B43;" />
                            }
                            else
                            {
                                <input type="text" value="@val" @oninput="@(e => HandleInputChanged(prop, indicator, e))" style="background: #131722; color: white; border: 1px solid #2B2B43; padding: 2px 5px; width: 60px; border-radius: 3px;" />
                            }
                        }
                    </div>
                }

                int childIndex = 0;
                foreach (var child in indicator.Indicators)
                {
                    @RenderIndicatorEditor(child, child.GetType().Name.Replace("Indicator", "") + " " + (++childIndex))
                }
            }
        </div>
    };
}